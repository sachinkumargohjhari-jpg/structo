{
  "name": "structo",
  "version": "1.0.0",
  "description": "Structo Engineering Suite Mobile App",
  "main": "app.js",
  "scripts": {
    "build": "mkdir -p www && cp index.html styles.css manifest.json service-worker.js sw-register.js icon.svg www/ && npx javascript-obfuscator app.js --output www/app.js",
    "add-android": "npx cap add android",
    "sync": "npx cap sync",
    "build-apk": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "javascript-obfuscator": "^4.1.0"
  }
}
