{
	"appId": "com.civilcalc.pro",
	"appName": "Structo",
	"webDir": "www",
	"bundledWebRuntime": false,
	"cordova": {
		"preferences": {
			"Orientation": "portrait"
		}
	},
	"plugins": {
		"FirebaseAuthentication": {
			"skipNativeAuth": false,
			"providers": [
				"google.com"
			]
		},
		"SplashScreen": {
			"launchShowDuration": 0,
			"launchAutoHide": true
		}
	}
}
